gameevent startup {
    declare global web_url = "http://4.tcp.ngrok.io:22799";
    declare global plot_data_stale = 0;

    start game_loop();
}

playerevent join {
    player.sendMessage(s"Hello " + player.name);
    plot_data_stale = 1;
}

process game_loop {
    repeat {
        if(plot_data_stale == 1 && game.ticksSinceStartup % 60 == 5) {
            send_plot_data();
        }
        wait(1);
    }
}