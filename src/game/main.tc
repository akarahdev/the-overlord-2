gameevent startup {
    declare global web_url = "http://4.tcp.ngrok.io:22799";
}

playerevent join {
    player.sendMessage(s"Hello " + player.name);
}

playerevent command {
    line command = game.eventCommand;
    line response = get_direct_llm_response(command);
    line json = response["json"] as dict;
    line actions = json["actions"];
    print(actions);
    allPlayers.sendMessage(s"<green>%default <gray>asked... <white>%var(command)");
    if(var.isType(actions, type="List")) {
        execute_actions(actions as list[dict]);
    } else {
        execute_node(actions as dict);
    }
}
