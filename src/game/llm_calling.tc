playerevent command {
    line command = game.eventCommand;
    line response = get_direct_llm_response("%default says " + command);
    line json = response["json"] as dict;
    line actions = json["actions"];
    print(actions);
    allPlayers.sendMessage(s"<green>%default<gray>: <white>%var(command)");
    chat_logs.append({"player": "%default", "ai_request": command});
    if(var.isType(actions, type="List")) {
        execute_actions(actions as list[dict]);
    } else {
        execute_node(actions as dict);
    }
}

function get_direct_llm_response(prompt: str): dict {
    line response: dict = workaround_web_request(web_url + "/simple_prompt", prompt);
    return response;
}

// this is needed because teerracotta beta bug
function workaround_web_request(web_url: str, prompt: str): dict {
    var.getWebResponse(
        web_url,
        prompt,
        codeFlow = "Synchronous",
        method = "Post",
        contentType = "application/json"
    );
    return line "@__TC_TMP_0" as dict;
}